# =============================================================================
# LOTO Mobile - Environment Variables
# =============================================================================
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Variables with EXPO_PUBLIC_ prefix are inlined into the client bundle
# and available via process.env.EXPO_PUBLIC_*
#
# IMPORTANT: Never commit .env.local or store secrets in EXPO_PUBLIC_ vars!
#
# @see https://docs.expo.dev/guides/environment-variables/
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — hlavný backend (databáza, auth, realtime)
# -----------------------------------------------------------------------------
# Kde nájdeš tieto hodnoty:
#   1. https://supabase.com → tvoj projekt → Settings → API
#   2. Skopíruj "Project URL" a "anon public" key
#
# BEZPEČNOSŤ:
#   - anon key je VEREJNÝ — môžeš ho commitnúť (je to zamýšlané)
#   - Bezpečnosť zabezpečuje Row Level Security v Supabase
#   - service_role key NIKDY nedávaj do mobilnej app!
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION (legacy — bude nahradené Supabase Realtime)
# -----------------------------------------------------------------------------
# Socket.io server URL — ponechané počas migrácie na Supabase
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Enable verbose logging
# EXPO_PUBLIC_DEBUG_LOGGING=true

# Enable mock data for offline development
# EXPO_PUBLIC_USE_MOCK_DATA=true

# -----------------------------------------------------------------------------
# AdMob — vyplň po vytvorení účtu na admob.google.com
# -----------------------------------------------------------------------------
# Bez týchto hodnôt používajú dev/preview buildy Googlove TESTOVACIE reklamy
# (app ID fallback je v app.config.ts, ad unit fallback v ads.ts).
# PRODUKČNÝ build BEZ týchto kľúčov reklamy vypne — pred vydaním ich nastav
# aj v EAS: `eas env:create --environment production --name EXPO_PUBLIC_ADMOB_...`
# POZOR: App ID sa zapisuje do natívneho buildu (prebuild) — po zmene treba
# nový binárny build, nestačí OTA update.
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-XXXX~XXXX
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-XXXX~XXXX
EXPO_PUBLIC_ADMOB_REWARDED_ID_ANDROID=ca-app-pub-XXXX/XXXX
EXPO_PUBLIC_ADMOB_REWARDED_ID_IOS=ca-app-pub-XXXX/XXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_ANDROID=ca-app-pub-XXXX/XXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_IOS=ca-app-pub-XXXX/XXXX

# -----------------------------------------------------------------------------
# Analytics (Firebase) — vyplň po vytvorení projektu
# -----------------------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# -----------------------------------------------------------------------------
# RevenueCat (IAP) — vyplň po vytvorení účtu
# -----------------------------------------------------------------------------
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# -----------------------------------------------------------------------------
# Sentry (Crash reporting) — vyplň po vytvorení projektu
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=
